{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Install: requirements",
        "type": "shell",
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
        "args": [
          "-m",
          "pip",
          "install",
          "-r",
          "requirements.txt"
        ],
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "problemMatcher": []
      },
      {
        "label": "Test: LLM connection",
        "type": "shell",
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
        "args": [
          "test_llm.py"
        ],
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "problemMatcher": [],
        "runOptions": {
          "runOn": "folderOpen"
        }
      },
      {
        "label": "Run: Backend Python Developer",
        "type": "shell",
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
